spec:
  extensions:
    helm:
      charts:
      - name: cilium
        chartname: oci://quay.io/cilium/charts/cilium
        version: "1.19.3"
        namespace: kube-system
        values: |
          gatewayAPI:
            enabled: true
          ipam:
            mode: kubernetes
          ipv4:
            enabled: false
          ipv6:
            enabled: true
          k8sServiceHost: {{ (_kubernetes_service_cidr | ansible.utils.ipv6) | ternary('::1', '127.0.0.1') }}
          k8sServicePort: 6443
          kubeProxyReplacement: true
          operator:
            replicas: 1
  network:
    kubeProxy:
      disabled: true
    provider: custom
