apiVersion: k0s.k0sproject.io/v1beta1
kind: ClusterConfig
metadata:
  name: k0s
  namespace: kube-system
spec:
  api:
    address: {{ _kubernetes_address }}
    ca:
      certificatesExpireAfter: 8760h0m0s
      expiresAfter: 87600h0m0s
    k0sApiPort: 9443
    port: 6443
  controllerManager: {}
  extensions:
    helm:
      concurrencyLevel: 5
      {% if _kubernetes_cni_type == "cilium" %}
      charts:
      - name: cilium
        chartname: oci://quay.io/cilium/charts/cilium
        version: "1.19.3"
        namespace: kube-system
        values: |
          gatewayAPI:
            enabled: true
          ipam:
            mode: kubernetes
          ipv4:
            enabled: false
          ipv6:
            enabled: true
          k8sServiceHost: ::1
          k8sServicePort: 6443
          kubeProxyReplacement: true
          operator:
            replicas: 1
      {% endif %}
  installConfig:
    users:
      etcdUser: etcd
      kineUser: kube-apiserver
      konnectivityUser: konnectivity-server
      kubeAPIserverUser: kube-apiserver
      kubeSchedulerUser: kube-scheduler
  konnectivity:
    adminPort: 8133
    agentPort: 8132
  network:
    clusterDomain: cluster.local
    dualStack:
      enabled: false
    kubeProxy:
      disabled: {{ (_kubernetes_cni_type == "cilium") | ternary('true', 'false') }}
      iptables:
        minSyncPeriod: 0s
        syncPeriod: 0s
      ipvs:
        minSyncPeriod: 0s
        syncPeriod: 0s
        tcpFinTimeout: 0s
        tcpTimeout: 0s
        udpTimeout: 0s
      metricsBindAddress: "[::]:10249"
      mode: iptables
      nftables:
        minSyncPeriod: 0s
        syncPeriod: 0s
    kuberouter:
      autoMTU: true
      hairpin: Enabled
      metricsPort: 8080
    nodeLocalLoadBalancing:
      enabled: false
      envoyProxy:
        apiServerBindPort: 7443
        konnectivityServerBindPort: 7132
      type: EnvoyProxy
    podCIDR: {{ _kubernetes_pod_cidr }}
    provider: {{ (_kubernetes_cni_type == "cilium") | ternary("custom", _kubernetes_cni_type) }}
    serviceCIDR: {{ _kubernetes_service_cidr }}
  scheduler: {}
  storage:
    etcd:
      ca:
        certificatesExpireAfter: 8760h0m0s
        expiresAfter: 87600h0m0s
      peerAddress: {{ _kubernetes_address }}
    type: etcd
  telemetry:
    enabled: false
